rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'nithishog31@gmail.com' || 
              request.auth.token.email == 'rkjthulasiraja@gmail.com' ||
              request.auth.token.email == 'nithishwarang@gmail.com');
    }

    // ── Bookings ──────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if request.auth != null && (
                    resource.data.userId == request.auth.uid || 
                    isAdmin()
                  );
      allow update: if request.auth != null && (
                      isAdmin() ||
                      (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['transactionId', 'paymentStatus']))
                    );
      allow delete: if isAdmin();
    }

    // ── User Tokens for Push ─────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Admin Private Notes ──────────────────────────────────────────
    match /adminNotes/{bookingId} {
      allow read, write: if isAdmin();
    }

    // ── Reviews ───────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}

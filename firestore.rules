rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Bookings ──────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if request.auth != null && (
                    resource.data.userId == request.auth.uid || 
                    request.auth.token.email == 'nithishog31@gmail.com'
                  );
      allow update: if request.auth != null && (
                      request.auth.token.email == 'nithishog31@gmail.com' ||
                      (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['transactionId', 'paymentStatus']))
                    );
      allow delete: if request.auth != null && 
                       request.auth.token.email == 'nithishog31@gmail.com';
    }

    // ── User Tokens for Push ─────────────────────────────────────────
    match /users/{userId} {
      // User can only write their own token
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can read all tokens to send push
      allow read: if request.auth != null && request.auth.token.email == 'nithishog31@gmail.com';
    }

    // ── Admin Private Notes ──────────────────────────────────────────
    match /adminNotes/{bookingId} {
      allow read, write: if request.auth != null &&
                             request.auth.token.email == 'nithishog31@gmail.com';
    }

    // ── Reviews ───────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
                               request.auth.token.email == 'nithishog31@gmail.com';
    }
  }
}
